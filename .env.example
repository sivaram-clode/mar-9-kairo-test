DATABASE_URL="postgresql://postgres:postgres@localhost:5432/linkedin_clone?schema=public"
NEXTAUTH_SECRET="change-me-in-production"
# Set NEXTAUTH_URL to your actual URL (especially behind Cloudflare Tunnel)
NEXTAUTH_URL="http://localhost:3000"
# Set to "true" when running behind a reverse proxy (Cloudflare Tunnel, nginx, etc.)
NEXTAUTH_TRUST_HOST="false"

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
